rules_version = '2';

// MODELO DE ACESSO
// As Netlify Functions e os jobs do GitHub Actions acessam o Firestore como
// SERVICE ACCOUNT (OAuth2 Bearer, ver netlify/functions/_lib/google-auth.js).
// Acesso de service account com papel IAM (roles/datastore.user) e
// ADMINISTRATIVO e ignora estas regras — por isso elas podem (e devem) negar
// todo o resto: nenhum cliente fala com o Firestore diretamente; todo acesso
// passa pelas funcoes, que fazem validacao e autorizacao em codigo.
//
// ORDEM DE PUBLICACAO (importante — fora de ordem derruba a producao):
//   1. Deployar o codigo com suporte a service account (fallback p/ ?key= ativo).
//   2. Criar a service account no GCP e configurar FIREBASE_SERVICE_ACCOUNT
//      no Netlify e nos secrets do GitHub Actions.
//   3. Confirmar nos logs: "[_lib] Firestore auth: service account (Bearer)".
//   4. SO ENTAO publicar estas regras (deny-all).
//   5. Depois, rotacionar/restringir a FIREBASE_API_KEY antiga no console GCP.

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
