# ── Firebase / Firestore ──────────────────────────────────────────────────────
# Project ID from Firebase Console → Project Settings
FIREBASE_PROJECT_ID=orthoradar

# Web API Key from Firebase Console → Project Settings → General
FIREBASE_API_KEY=

# ── Resend (email delivery) ───────────────────────────────────────────────────
# From Resend.com → API Keys
RESEND_API_KEY=

# ── Anthropic / Claude ────────────────────────────────────────────────────────
# From console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# Modelo usado por todas as features de IA. Padrão do projeto: claude-fable-5.
# Deixe vazio para usar o padrão (Fable 5), ou defina para trocar globalmente.
ANTHROPIC_MODEL=

# Overrides opcionais por feature (têm precedência sobre ANTHROPIC_MODEL).
# Útil para baratear features de alto volume mantendo Fable 5 nas demais.
#   EDITORIAL_MODEL  — nota editorial dos digests (daily/weekly)
#   ACHADO_MODEL     — nota do "Achado da Semana"
#   ENRICH_MODEL     — enriquecimento de artigos (ingestão em massa)
#   CLINICAL_MODEL   — síntese das perguntas clínicas
EDITORIAL_MODEL=
ACHADO_MODEL=
ENRICH_MODEL=
CLINICAL_MODEL=

# ── Google Cloud Text-to-Speech (podcast Pro) ─────────────────────────────────
# Chave de API do MESMO projeto Google/Firebase, com a API "Cloud Text-to-Speech"
# habilitada. Usada só para vozes Standard (4M caracteres/mês grátis).
# O guardrail em _lib/tts-budget.js NUNCA deixa passar de 3.2M/mês (teto operacional).
# Sem esta chave, a geração de podcast é pulada sem quebrar o pipeline.
GOOGLE_TTS_API_KEY=

# Service account (JSON cru ou base64) do projeto — para upload do áudio no
# Cloud Storage / Firebase Storage. Mesma conta pode servir p/ blindar o Firestore.
GCP_SERVICE_ACCOUNT_JSON=
# Bucket do Storage. RECOMENDADO setar explicitamente: projetos Firebase antigos
# usam {projectId}.appspot.com (default), mas projetos novos usam
# {projectId}.firebasestorage.app — confira no console (Storage) o nome real.
GCS_BUCKET=

# (opcional) Modelo do roteiro do podcast — herda ANTHROPIC_MODEL (Fable 5) se vazio.
PODCAST_MODEL=

# ── NCBI / PubMed (optional) ──────────────────────────────────────────────────
# Increases rate limit from 3 req/s → 10 req/s
# Register free at: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# ── Site URL (used in emails for tracking links and CTAs) ────────────────────
# Your production domain — no trailing slash
SITE_URL=https://odontofeed.com.br

# ── Unsubscribe HMAC secret ───────────────────────────────────────────────────
# Any random string; used to sign unsubscribe tokens (OBRIGATÓRIO — sem ele os
# digests não são enviados e os links de descadastro são recusados).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
UNSUBSCRIBE_SECRET=

# ── Admin secret ──────────────────────────────────────────────────────────────
# Protege endpoints administrativos e de pipeline (admin-status, get-feature-
# analytics, e as invocações HTTP de ingest-*/process-article).
# Envie via header x-admin-secret ou query ?secret=. Sem ele, esses endpoints
# HTTP são bloqueados (o CI usa `node <arquivo>` e não é afetado).
ADMIN_SECRET=

# ── Runtime config ────────────────────────────────────────────────────────────
# Max articles to enrich with AI per run (controls Claude cost)
AI_BATCH_SIZE=20

# Log verbosity: debug | info | warn | error
LOG_LEVEL=info
