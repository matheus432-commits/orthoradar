# ── Firebase / Firestore ──────────────────────────────────────────────────────
# Project ID from Firebase Console → Project Settings
FIREBASE_PROJECT_ID=orthoradar

# Web API Key from Firebase Console → Project Settings → General
FIREBASE_API_KEY=

# ── Resend (email delivery) ───────────────────────────────────────────────────
# From Resend.com → API Keys
RESEND_API_KEY=

# ── Anthropic / Claude ────────────────────────────────────────────────────────
# From console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── NCBI / PubMed (optional) ──────────────────────────────────────────────────
# Increases rate limit from 3 req/s → 10 req/s
# Register free at: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# ── Runtime config ────────────────────────────────────────────────────────────
# Max articles to enrich with AI per run (controls Claude cost)
AI_BATCH_SIZE=20

# Log verbosity: debug | info | warn | error
LOG_LEVEL=info
